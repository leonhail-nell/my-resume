# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Local dev URL (use https://your-domain.com in prod)
AUTH_URL=http://localhost:3000

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Only this GitHub username can sign in to /admin
ADMIN_GITHUB_USERNAME=leonhail-nell

# --- Database (Vercel Postgres) ---
# In production these are auto-injected by Vercel.
# Locally, copy values from your Vercel Postgres dashboard.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Blob storage (Vercel Blob) ---
# In production this is auto-injected by Vercel.
BLOB_READ_WRITE_TOKEN=
